<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ExtensionManifest
  Version="11.0"
  ExtensionBundleId="com.adobe.animatemcp.bridge"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="Adobe Animate MCP Bridge"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="ExtensionManifest-v11.xsd">
  <ExtensionList>
    <Extension Id="com.adobe.animatemcp.bridge.panel" Version="1.0.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="FLPR" Version="[0.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.adobe.animatemcp.bridge.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Adobe Animate MCP Bridge</Menu>
          <Geometry>
            <Size>
              <Height>520</Height>
              <Width>400</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
